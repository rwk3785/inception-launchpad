# ---------------------------------------------------------------------------
# GitHub API credentials
# ---------------------------------------------------------------------------

# Personal access token with "repo" and "actions" scopes.
# Required to read agent manifests and trigger/monitor GitHub Actions workflows.
GITHUB_TOKEN=ghp_your_token_here

# GitHub repository owner (your GitHub username or org name).
GITHUB_REPO_OWNER=rwk3785

# GitHub repository name that hosts the agent manifests and workflows.
GITHUB_REPO_NAME=inception-launchpad

# Full repo reference in "owner/repo" format — used to generate display links.
NEXT_PUBLIC_GITHUB_REPO=rwk3785/inception-launchpad
